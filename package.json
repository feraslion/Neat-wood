
"main": "dist-electron/main.js",
"scripts": {
  "dev": "vite",
  "build:web": "vite build",
  "build:electron:dev": "tsc -p tsconfig.electron.json && electron .",
  "build:electron": "npm run build:web && tsc -p tsconfig.electron.json && vite build --outDir dist && electron-builder --win",
  "prepare:capacitor": "npm run build:web && npx cap sync",
  "build:android": "npm run prepare:capacitor && npx cap open android"
},
"build": {
  "appId": "com.yourcompany.neatwood",
  "productName": "NeatWood",
  "files": [
    "dist/**",
    "dist-electron/**",
    "node_modules/**",
    "package.json"
  ],
  "win": {
    "target": ["nsis"],
    "icon": "build/icons/win/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true
  }
}
